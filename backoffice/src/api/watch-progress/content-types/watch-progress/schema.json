{
  "kind": "collectionType",
  "collectionName": "watch_progresses",
  "info": {
    "singularName": "watch-progress",
    "pluralName": "watch-progresses",
    "displayName": "Watch Progress",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "itemType": {
      "type": "enumeration",
      "enum": ["movie", "episode"],
      "required": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "movie": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::movie.movie"
    },
    "episode": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::episode.episode"
    },
    "positionSeconds": {
      "type": "integer",
      "min": 0
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "lastWatchedAt": {
      "type": "datetime"
    }
  }
}
