{
  "kind": "collectionType",
  "collectionName": "series",
  "info": {
    "singularName": "series",
    "pluralName": "series",
    "displayName": "Series",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "synopsis": {
      "type": "text"
    },
    "genres": {
      "type": "json"
    },
    "poster": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "seasons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::season.season",
      "mappedBy": "series"
    },
    "episodes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::episode.episode",
      "mappedBy": "series"
    }
  }
}
